# Copier ce fichier en .env et adapter si besoin
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=redispass

# Durée de vie d'une session en secondes (15 minutes par défaut)
SESSION_TTL_SECONDS=900

# Port d'écoute de l'API
PORT=3001

# Origine autorisée pour le CORS (frontend Vite)
CORS_ORIGIN=http://localhost:5173
